# AWS Configuration
environment = "dev"
region      = "eu-west-2"

# Network
vpc_cidr            = "10.0.0.0/16"
public_subnet_cidr  = "10.0.1.0/24"
private_subnet_cidr = "10.0.2.0/24"

# EC2
inst_type  = "t3.micro"
ubuntu_ami = "ami-xxxxxxxxx"

# SSH
key_name        = "aws_key"
public_key_path = "~/.ssh/aws_key.pub"